# Environment Configuration
# Copy this file to .env and fill in your values

# OpenAI API Key (used ONLY in Segment 3 for bilingual narration)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model to use for narration (cheapest coherent option)
OPENAI_MODEL=gpt-4o-mini

# API settings
API_HOST=0.0.0.0
API_PORT=8000
